{
  "name": "@anysk/telegramma-nestjs",
  "version": "4.0.0",
  "description": "Telegraf module for NestJS",
  "keywords": [
    "nest",
    "nestjs",
    "nestjs-module",
    "telegraf",
    "telegram",
    "telegram bot",
    "telegram bot api",
    "bot",
    "bot api",
    "bot framework"
  ],
  "homepage": "https://github.com/AnySk/telegramma-nestjs",
  "bugs": {
    "url": "https://github.com/AnySk/telegramma-nestjs/issues"
  },
  "repository": "git@github.com:AnySk/telegramma-nestjs.git",
  "license": "MIT",
  "author": "AnySk <develop@samoilenko.tk>",
  "contributors": [
    {
      "name": "Timur Samoilenko",
      "email": "develop@samoilenko.tk"
    }
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "precommit": "lint-staged",
    "prepublish:npm": "npm run build",
    "publish:npm": "npm publish --access public",
    "test": "",
    "typedoc:build": "typedoc --tsconfig ./tsconfig.typedoc.json",
    "docs:dev": "vitepress dev",
    "docs:build": "vitepress build",
    "docs:preview": "vitepress preview"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "commitlint -c .commitlintrc.json -E HUSKY_GIT_PARAMS"
    }
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-angular": "20.5.3",
    "@nestjs/common": "^11.1.0",
    "@nestjs/core": "^11.1.0",
    "@types/lodash": "4.17.24",
    "@typescript-eslint/eslint-plugin": "8.61.1",
    "@typescript-eslint/parser": "8.61.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.4",
    "reflect-metadata": "^0.2.2",
    "@anysk/telegramma": "^4.18.0",
    "typedoc": "0.28.19",
    "typescript": "5.9.3",
    "vitepress": "^1.6.3"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@anysk/telegramma": "^4.18.0",
    "reflect-metadata": "^0.2.2",
    "typescript": "^4.1.2 || ^5.0.0"
  }
}
